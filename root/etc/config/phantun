# phantun configuration
# Global options
config global 'global'
	# GitHub release version of Phantun to fetch on init
	option version 'v0.8.1'
	# DNS server used when resolving client peer domains (optional; falls back
	# to the system resolver if empty or unreachable).
	option dns_server ''
	# How often (seconds) the DDNS monitor re-checks watched domains.
	option check_interval '60'
	# Force resolver DNS traffic out the physical WAN, bypassing the tunnel,
	# so a domain-based client can always reconnect after the tunnel drops.
	option bypass_proxy '1'
	# Physical WAN interface for the DNS bypass. Empty = autodetect (wan).
	option wan_iface ''
	option log_max '100'

